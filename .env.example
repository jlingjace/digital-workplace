# Database
DATABASE_URL="postgresql://username:password@localhost:5432/digital_workplace"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"  # Generate with: openssl rand -base64 32

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Admin access control (comma-separated email addresses)
ADMIN_EMAILS="admin@company.com,hr@company.com"
# Or use a domain-wide allow:
ADMIN_DOMAIN="company.com"
